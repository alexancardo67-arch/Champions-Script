local function TeleportToGun()
    local GunPart = workspace:FindFirstChild("GunDrop") or workspace:FindFirstChild("Gun")
    if not GunPart then
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj.Name == "GunDrop" then GunPart = obj break end
        end
    end

    if GunPart and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = LocalPlayer.Character.HumanoidRootPart
        local OldCFrame = hrp.CFrame
        
        -- Bypass de velocidad: Va, espera una milésima y regresa
        hrp.CFrame = GunPart.CFrame + Vector3.new(0, 2, 0)
        task.wait(0.25)
        hrp.CFrame = OldCFrame
    end
end

