-- PESTAÑA: VISUALES (ESP / Chams por Rol)
local VisualsTab = Window:CreateTab("👁️ Visuales", 4483362458)

local function ObtenerColorRol(player)
    -- Lógica para detectar roles en MM2
    if player.Backpack:FindFirstChild("Knife") or (player.Character and player.Character:FindFirstChild("Knife")) then
        return Color3.fromRGB(255, 0, 0) -- Asesino (Rojo)
    elseif player.Backpack:FindFirstChild("Gun") or (player.Character and player.Character:FindFirstChild("Gun")) then
        return Color3.fromRGB(0, 0, 255) -- Sheriff (Azul)
    else
        return Color3.fromRGB(0, 255, 0) -- Inocente (Verde)
    end
end

VisualsTab:CreateButton({
   Name = "Activar Chams & ESP Líneas",
   Callback = function()
       Rayfield:Notify({Title = "Sukuna Hub", Content = "Cargando ojos del dominio (ESP)...", Duration = 3})
       
       game:GetService("RunService").RenderStepped:Connect(function()
           for _, player in pairs(game.Players:GetPlayers()) do
               if player ~= LP and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                   local char = player.Character
                   local color = ObtenerColorRol(player)
                   
                   -- 1. CHAMS (Highlight)
                   local highlight = char:FindFirstChild("SukunaChams")
                   if not highlight then
                       highlight = Instance.new("Highlight")
                       highlight.Name = "SukunaChams"
                       highlight.Parent = char
                   end
                   highlight.FillColor = color
                   highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                   highlight.FillTransparency = 0.4
                   
                   -- 2. ESP LÍNEAS
                   local hrp = char.HumanoidRootPart
                   local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                   
                   local line = char:FindFirstChild("SukunaLine")
                   if onScreen then
                       if not line then
                           -- Usamos un Adornment en lugar de Drawing puro para evitar lag en Delta movil
                           line = Instance.new("LineHandleAdornment")
                           line.Name = "SukunaLine"
                           line.Length = (Camera.CoordinateFrame.p - hrp.Position).Magnitude
                           line.Thickness = 3
                           line.AlwaysOnTop = true
                           line.ZIndex = 10
                           line.Parent = char
                       end
                       line.Color3 = color
                       line.Adornee = hrp
                   else
                       if line then line:Destroy() end
                   end
               end
           end
       end)
   end,
})

-- PESTAÑA: MOVILES / EXPLOITS (Ghost / Speed)
local MiscTab = Window:CreateTab("⚡ Movimiento", 4483362458)

MiscTab:CreateToggle({
   Name = "Ghost Mode (Invisible/Atravesar)",
   CurrentValue = false,
   Callback = function(Value)
       GhostModeEnabled = Value
       if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
           LP.Character.HumanoidRootPart.CanCollide = not Value
           for _, parts in pairs(LP.Character:GetChildren()) do
               if parts:IsA("BasePart") then
                   parts.CanCollide = not Value
               end
           end
       end
   end,
})

MiscTab:CreateToggle({
   Name = "Speed Glitch (C-Frame)",
   CurrentValue = false,
   Callback = function(Value)
       SpeedGlitchEnabled = Value
   end,
})

-- Bucles lógicos internos (Aimbot, FOV, Speed)
game:GetService("RunService").RenderStepped:Connect(function()
   -- Actualizar posición del círculo FOV
   if FOVCircle.Visible then
       FOVCircle.Position = game:GetService("UserInputService"):GetMouseLocation()
   end
   
   -- Speed Glitch
   if SpeedGlitchEnabled and LP.Character and LP.Character:FindFirstChild("Humanoid") then
       if LP.Character.Humanoid.MoveDirection.Magnitude > 0 then
           LP.Character:TranslateBy(LP.Character.Humanoid.MoveDirection * 0.4) -- Ajusta el número para ir más rápido
       end
   end
   
   -- Lógica de Aimbot Tradicional
   if AimbotEnabled then
       local target = nil
       local shortestDistance = math.huge
       for _, v in pairs(game.Players:GetPlayers()) do
           if v ~= LP and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
               local pos, onScreen = Camera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
               if onScreen then
                   local mousePos = game:GetService("UserInputService"):GetMouseLocation()
                   local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                   if dist < shortestDistance then
                       target = v
                       shortestDistance = dist
                   end
               end
           end
       end
       if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
           Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Character.HumanoidRootPart.Position)
       end
   end
end)

