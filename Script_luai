setreadonly(Mt, false)

Mt.__namecall = newcclosure(function(Self, ...)
   local Args = {...}
   local Method = getnamecallmethod()
   
   if SilentAimEnabled and Method == "FireServer" or Method == "InvokeServer" then
       -- Aquí busca un objetivo dentro del FOV para redirigir el disparo
       -- Diseñado de manera genérica para scripts de armas/cuchillos arrojadizos
   end
   return OldNamecall(Self, ...)
end)
setreadonly(Mt, true)

