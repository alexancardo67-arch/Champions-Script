local function GetPlayerRole(player)
    if not player then return "Innocent" end
    
    -- Detección por ítems en mano o mochila
    local char = player.Character
    if (char and char:FindFirstChild("Knife")) or player.Backpack:FindFirstChild("Knife") then
        return "Murder"
    elseif (char and char:FindFirstChild("Gun")) or player.Backpack:FindFirstChild("Gun") then
        return "Sheriff"
    end
    
    -- Detección por variables internas de MM2
    local pd = player:FindFirstChild("PlayerData") or player:FindFirstChild("temp")
    if pd and pd:FindFirstChild("Role") then
        local r = pd.Role.Value
        if r == "Murderer" then return "Murder" end
        if r == "Sheriff" or r == "Hero" then return "Sheriff" end
    end
    return "Innocent"
end

local function ApplyHighlight(player)
    if player == LocalPlayer then return end
    
    local function ManageCharacter(char)
        if not char then return end
        
        local hl = char:FindFirstChild("SukunaHighlight")
        if not hl then
            hl = Instance.new("Highlight")
            hl.Name = "SukunaHighlight"
            hl.Parent = char
        end
        
        hl.FillOpacity = 0.35
        hl.OutlineOpacity = 0.85
        
        local role = GetPlayerRole(player)
        if role == "Murder" then
            hl.FillColor = Color3.fromRGB(255, 20, 20)      -- Rojo Vivo
            hl.OutlineColor = Color3.fromRGB(255, 0, 0)
        elseif role == "Sheriff" then
            hl.FillColor = Color3.fromRGB(20, 20, 255)     -- Azul Eléctrico
            hl.OutlineColor = Color3.fromRGB(0, 0, 255)
        else
            hl.FillColor = Color3.fromRGB(20, 255, 20)     -- Verde Esmeralda
            hl.OutlineColor = Color3.fromRGB(0, 255, 0)
        end
        hl.Adornee = char
        hl.Enabled = ESP_Enabled
    end

    player.CharacterAdded:Connect(ManageCharacter)
    if player.Character then ManageCharacter(player.Character) end
end

