-- Función exacta para conseguir el Rol en MM2
local function GetPlayerRole(p)
    if not p or not p:FindFirstChild("Backpack") then return "Innocent" end
    if p.Backpack:FindFirstChild("Knife") or (p.Character and p.Character:FindFirstChild("Knife")) then
        return "Murder"
    elseif p.Backpack:FindFirstChild("Gun") or (p.Character and p.Character:FindFirstChild("Gun")) then
        return "Sheriff"
    end
    return "Innocent"
end

local function GetRoleColor(p)
    local role = GetPlayerRole(p)
    if role == "Murder" then return Color3.fromRGB(255, 0, 0) end   -- Rojo Asesino
    if role == "Sheriff" then return Color3.fromRGB(0, 0, 255) end  -- Azul Sheriff
    return Color3.fromRGB(0, 255, 0)                                -- Verde Inocente
end

SectionVisuals:NewButton("Activar Chams y ESP Perfectos", "Revela las almas en el mapa", function()
    game:GetService("RunService").RenderStepped:Connect(function()
        for _, player in pairs(game.Players:GetPlayers()) do
            if player ~= LP and player.Character then
                local char = player.Character
                local color = GetRoleColor(player)
                
                -- 1. CHAMS (Resaltado de silueta)
                local highlight = char:FindFirstChild("SukunaCham")
                if not highlight then
                    highlight = Instance.new("Highlight")
                    highlight.Name = "SukunaCham"
                    highlight.Parent = char
                end
                highlight.FillColor = color
                highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                highlight.FillTransparency = 0.4
                highlight.OutlineTransparency = 0
                
                -- 2. ESP LÍNEAS (Desde abajo de la pantalla hasta el jugador)
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local vector, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                    local line = char:FindFirstChild("SukunaLine")
                    
                    if onScreen then
                        if not line then
                            line = Instance.new("LineHandleAdornment")
                            line.Name = "SukunaLine"
                            line.Length = 0
                            line.Thickness = 4
                            line.ZIndex = 5
                            line.AlwaysOnTop = true
                            line.Parent = char
                        end
                        line.Color3 = color
                        line.Adornee = hrp
                    else
                        if line then line:Destroy() end
                    end
                end
            end
        end
    end)
end)

