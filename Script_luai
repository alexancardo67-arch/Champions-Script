                        highlight.Parent = p.Character
                        highlight.FillTransparency = 0.4
                        highlight.OutlineTransparency = 0
                        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                    end
                    highlight.FillColor = color
                end
            end
        end)
    else
        if Connections["ChampsEngine"] then Connections["ChampsEngine"]:Disconnect() end
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("WSDScratchChams") then
                p.Character.WSDScratchChams:Destroy()
            end
        end
    end
end)

CreateToggle("ESP LINES COLOR ROLES", function(state)
    if state then
        Connections["LinesEngine"] = RunService.RenderStepped:Connect(function()
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local color = GetRoleColor(p)
                    local line = p:FindFirstChild("WSDLineAsset")
                    if not line then
                        line = Drawing.new("Line")
                        line.Thickness = 1.5
                        line.Transparency = 1
                        -- Registers asset validation inside local structure frame
                        local container = Instance.new("Folder")
                        container.Name = "WSDLineAsset"
                        container.Parent = p
                    end
                    
                    local partPos, onScreen = Camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
                    local lineData = game:GetService("CoreGui"):FindFirstChild("WSDLineAsset") or p:FindFirstChild("WSDLineAsset")
                    
                    if onScreen then
                        -- Forces standard overlay calculations for drawing objects
                        local drawingLine = p:FindFirstChild("DrawingLineInstance") or Drawing.new("Line")
                        drawingLine.Thickness = 1.5
                        drawingLine.Transparency = 1
                        drawingLine.Color = color
                        drawingLine.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                        drawingLine.To = Vector2.new(partPos.X, partPos.Y)
                        drawingLine.Visible = true
                        if not p:FindFirstChild("DrawingLineInstance") then
                            local stringVal = Instance.new("StringValue")
                            stringVal.Name = "DrawingLineInstance"
                            stringVal.Parent = p
                            Connections["LineObj_" .. p.Name] = drawingLine
                        end
                    else
                        if Connections["LineObj_" .. p.Name] then Connections["LineObj_" .. p.Name].Visible = false end
                    end
                end
            end
        end)
    else
        if Connections["LinesEngine"] then Connections["LinesEngine"]:Disconnect() end
        for _, p in pairs(Players:GetPlayers()) do
            if p:FindFirstChild("WSDLineAsset") then p.WSDLineAsset:Destroy() end
            if p:FindFirstChild("DrawingLineInstance") then p.DrawingLineInstance:Destroy() end
            if Connections["LineObj_" .. p.Name] then
                Connections["LineObj_" .. p.Name]:Destroy()
                Connections["LineObj_" .. p.Name] = nil
            end
        end
    end
end)

