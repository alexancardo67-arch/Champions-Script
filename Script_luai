local function CreateToggle(name, callback)
    local state = false
    local TFrame = Instance.new("Frame")
    TFrame.Parent = ContentFrame
    TFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 22)
    
    local TFCorn = Instance.new("UICorner")
    TFCorn.CornerRadius = UDim.new(0, 6)
    TFCorn.Parent = TFrame

    local Label = Instance.new("TextLabel")
    Label.Parent = TFrame
    Label.BackgroundTransparency = 1
    Label.Position = UDim2.new(0, 10, 0, 0)
    Label.Size = UDim2.new(1, -55, 1, 0)
    Label.Font = Enum.Font.GothamSemibold
    Label.Text = name
    Label.TextColor3 = Color3.fromRGB(200, 200, 200)
    Label.TextSize = 11
    Label.TextXAlignment = Enum.TextXAlignment.Left

    local Switch = Instance.new("TextButton")
    Switch.Parent = TFrame
    Switch.AnchorPoint = Vector2.new(1, 0.5)
    Switch.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
    Switch.Position = UDim2.new(1, -8, 0.5, 0)
    Switch.Size = UDim2.new(0, 34, 0, 16)
    Switch.Text = ""

    local SCorn = Instance.new("UICorner")
    SCorn.CornerRadius = UDim.new(1, 0)
    SCorn.Parent = Switch

    local Indicator = Instance.new("Frame")
    Indicator.Parent = Switch
    Indicator.AnchorPoint = Vector2.new(0, 0.5)
    Indicator.BackgroundColor3 = Color3.fromRGB(140, 140, 140)
    Indicator.Position = UDim2.new(0, 2, 0.5, 0)
    Indicator.Size = UDim2.new(0, 12, 0, 12)

    local ICorn = Instance.new("UICorner")
    ICorn.CornerRadius = UDim.new(1, 0)
    ICorn.Parent = Indicator

    Switch.MouseButton1Click:Connect(function()
        state = not state
        Toggles[name] = state
        if state then
            Switch.BackgroundColor3 = Color3.fromRGB(120, 20, 20)
            Indicator.BackgroundColor3 = Color3.fromRGB(255, 40, 40)
            Indicator.Position = UDim2.new(1, -14, 0.5, 0)
        else
            Switch.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
            Indicator.BackgroundColor3 = Color3.fromRGB(140, 140, 140)
            Indicator.Position = UDim2.new(0, 2, 0.5, 0)
        end
        callback(state)
    end)
end

local function CreateSlider(name, min, max, default, configKey, callback)
    local SFrame = Instance.new("Frame")
    SFrame.Parent = ContentFrame
    SFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 22)
    
    local SFCorn = Instance.new("UICorner")
    SFCorn.CornerRadius = UDim.new(0, 6)
    SFCorn.Parent = SFrame

    local Label = Instance.new("TextLabel")
    Label.Parent = SFrame
    Label.BackgroundTransparency = 1
    Label.Position = UDim2.new(0, 10, 0, 0)
    Label.Size = UDim2.new(1, -60, 1, 0)
    Label.Font = Enum.Font.GothamSemibold
    Label.Text = name
    Label.TextColor3 = Color3.fromRGB(180, 180, 180)
    Label.TextSize = 11
    Label.TextXAlignment = Enum.TextXAlignment.Left

    local VBox = Instance.new("TextBox")
    VBox.Parent = SFrame
    VBox.AnchorPoint = Vector2.new(1, 0.5)
    VBox.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    VBox.Position = UDim2.new(1, -8, 0.5, 0)
    VBox.Size = UDim2.new(0, 45, 0, 22)
    VBox.Font = Enum.Font.GothamSemibold
    VBox.Text = tostring(default)
    VBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    VBox.TextSize = 11
    VBox.ClearTextOnFocus = false

    VBox.FocusLost:Connect(function()
        local val = tonumber(VBox.Text)
        if val then
            val = math.clamp(val, min, max)
            VBox.Text = tostring(val)
            Config[configKey] = val
            callback(val)
        else
            VBox.Text = tostring(Config[configKey])
        end
    end)
    callback(default)
end

