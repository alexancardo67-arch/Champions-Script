CreateButton("💥 Ejecutar Fling Target", function()
    local targetName = string.lower(TargetInput.Text)
    local found = nil
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and string.sub(string.lower(p.Name), 1, #targetName) == targetName then found = p break end
    end
    if found and found.Character and found.Character:FindFirstChild("HumanoidRootPart") and RootPart then
        pcall(function()
            local enemyRoot = found.Character.HumanoidRootPart
            local oldCFrame = RootPart.CFrame
            local BV = Instance.new("BodyVelocity") BV.Velocity = Vector3.new(0,0,0) BV.MaxForce = Vector3.new(math.huge,math.huge,math.huge) BV.Parent = RootPart
            local BAV = Instance.new("BodyAngularVelocity") BAV.AngularVelocity = Vector3.new(0,99999,0) BAV.MaxTorque = Vector3.new(math.huge,math.huge,math.huge) BAV.Parent = RootPart
            for i = 1, 35 do
                if enemyRoot then RootPart.CFrame = enemyRoot.CFrame + Vector3.new(0,0.5,0) end
                task.wait(0.02)
            end
            BV:Destroy() BAV:Destroy() RootPart.CFrame = oldCFrame
        end)
    end
end)

CreateToggle("Ver Roles (ESP Paredes)", function(state)
    roleESP = state
    task.spawn(function()
        while roleESP do
            task.wait(1)
            pcall(function()
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        local char = p.Character
                        local box = char:FindFirstChild("RoleHighlight") or Instance.new("Highlight")
                        box.Name = "RoleHighlight" box.Parent = char box.Adornee = char box.FillTransparency = 0.5
                        if p.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife") then box.FillColor = Color3.fromRGB(255,0,0)
                        elseif p.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun") then box.FillColor = Color3.fromRGB(0,0,255)
                        else box.FillColor = Color3.fromRGB(0,255,0) end
                    end
                end
            end)
        end
        if not roleESP then
            for _, p in pairs(Players:GetPlayers()) do
                if p.Character and p.Character:FindFirstChild("RoleHighlight") then p.Character.RoleHighlight:Destroy() end
            end
        end
    end)
end)

