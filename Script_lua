    Label.BackgroundTransparency = 1
    Label.Position = UDim2.new(0, 12, 0, 5)
    Label.Size = UDim2.new(0, 150, 0, 20)
    Label.Font = Enum.Font.GothamSemibold
    Label.Text = name
    Label.TextColor3 = Color3.fromRGB(200, 200, 200)
    Label.TextSize = 14
    Label.TextXAlignment = Enum.TextXAlignment.Left

    local ValueBox = Instance.new("TextBox")
    ValueBox.Parent = SliderFrame
    ValueBox.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
    ValueBox.Position = UDim2.new(1, -50, 0, 5)
    ValueBox.Size = UDim2.new(0, 40, 0, 20)
    ValueBox.Font = Enum.Font.GothamSemibold
    ValueBox.Text = tostring(default)
    ValueBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    ValueBox.TextSize = 12
    ValueBox.ClearTextOnFocus = false

    local VBCorner = Instance.new("UICorner")
    VBCorner.CornerRadius = UDim.new(0, 4)
    VBCorner.Parent = ValueBox

    ValueBox.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            local val = tonumber(ValueBox.Text)
            if val then
                val = math.clamp(val, min, max)
                ValueBox.Text = tostring(val)
                Config[configKey] = val
                callback(val)
            else
                ValueBox.Text = tostring(Config[configKey])
            end
        end
    end)
    callback(default)
end

