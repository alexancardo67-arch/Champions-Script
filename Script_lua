CreateToggle("Modo Invisible Total (Ghost)", function(state)
    invisibleMode = state
    pcall(function()
        if invisibleMode and RootPart then
            savedInvisibleCFrame = RootPart.CFrame
            local lowerTorso = Character:FindFirstChild("LowerTorso") or Character:FindFirstChild("Torso")
            if lowerTorso then
                local rootJoint = RootPart:FindFirstChild("RootJoint") or lowerTorso:FindFirstChild("RootJoint")
                if rootJoint then invisibleClone = rootJoint:Clone() rootJoint:Destroy() end
            end
            RootPart.CFrame = savedInvisibleCFrame * CFrame.new(0, -25, 0)
        else
            if invisibleClone and RootPart then
                local lowerTorso = Character:FindFirstChild("LowerTorso") or Character:FindFirstChild("Torso")
                if lowerTorso then invisibleClone.Parent = lowerTorso end
            end
            if savedInvisibleCFrame and RootPart then RootPart.CFrame = savedInvisibleCFrame end
        end
    end)
end)

