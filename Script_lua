    local ToggleFrame = Instance.new("Frame")
    ToggleFrame.Name = name .. "_Toggle"
    ToggleFrame.Parent = ContentFrame
    ToggleFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
    
    local TFCorner = Instance.new("UICorner")
    TFCorner.CornerRadius = UDim.new(0, 8)
    TFCorner.Parent = ToggleFrame

    local TFStroke = Instance.new("UIStroke")
    TFStroke.Color = Color3.fromRGB(40, 40, 45)
    TFStroke.Thickness = 1
    TFStroke.Parent = ToggleFrame

    local Label = Instance.new("TextLabel")
    Label.Parent = ToggleFrame
    Label.BackgroundTransparency = 1
    Label.Position = UDim2.new(0, 12, 0, 0)
    Label.Size = UDim2.new(1, -60, 1, 0)
    Label.Font = Enum.Font.GothamSemibold
    Label.Text = name
    Label.TextColor3 = Color3.fromRGB(200, 200, 200)
    Label.TextSize = 14
    Label.TextXAlignment = Enum.TextXAlignment.Left

    local Switch = Instance.new("TextButton")
    Switch.Parent = ToggleFrame
    Switch.AnchorPoint = Vector2.new(1, 0.5)
    Switch.BackgroundColor3 = Color3.fromRGB(30, 30, 35) -- OFF Color
    Switch.Position = UDim2.new(1, -10, 0.5, 0)
    Switch.Size = UDim2.new(0, 40, 0, 22)
    Switch.Text = ""

    local SCorner = Instance.new("UICorner")
    SCorner.CornerRadius = UDim.new(1, 0)
    SCorner.Parent = Switch

    local Indicator = Instance.new("Frame")
    Indicator.Parent = Switch
    Indicator.AnchorPoint = Vector2.new(0, 0.5)
    Indicator.BackgroundColor3 = Color3.fromRGB(100, 100, 105) -- OFF Indicator Color
    Indicator.Position = UDim2.new(0, 3, 0.5, 0)
    Indicator.Size = UDim2.new(0, 16, 0, 16)

    local ICorner = Instance.new("UICorner")
    ICorner.CornerRadius = UDim.new(1, 0)
    ICorner.Parent = Indicator

    Switch.MouseButton1Click:Connect(function()
        state = not state
        Toggles[name] = state
        
        if state then
            Switch:TweenBackgroundColor3(Color3.fromRGB(100, 20, 20), 0.2) -- Dark Red Background
            Indicator:TweenBackgroundColor3(Color3.fromRGB(255, 50, 50), 0.2) -- Bright Red Dot
            Indicator:TweenPosition(UDim2.new(1, -19, 0.5, 0), "Out", "Quad", 0.2)
        else
            Switch:TweenBackgroundColor3(Color3.fromRGB(30, 30, 35), 0.2)
            Indicator:TweenBackgroundColor3(Color3.fromRGB(100, 100, 105), 0.2)
            Indicator:TweenPosition(UDim2.new(0, 3, 0.5, 0), "Out", "Quad", 0.2)
        end
        callback(state)
    end)
end

