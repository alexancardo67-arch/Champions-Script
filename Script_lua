-- FUNCIÓN AUXILIAR PARA CREAR BOTONES DE ACTIVACIÓN (TOGGLES)
local function CreateToggle(name, text, callback)
    local Btn = Instance.new("TextButton")
    Btn.Name = name
    Btn.Size = UDim2.new(1, -10, 0, 40)
    Btn.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
    Btn.Text = text .. " [OFF]"
    Btn.TextColor3 = Color3.fromRGB(200, 200, 200)
    Btn.TextSize = 16
    Btn.Font = Enum.Font.SourceSans
    Btn.Parent = Container
    
    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(0, 6)
    Corner.Parent = Btn
    
    local active = false
    Btn.MouseButton1Click:Connect(function()
        active = not active
        if active then
            Btn.BackgroundColor3 = Color3.fromRGB(130, 50, 200)
            Btn.Text = text .. " [ON]"
            Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        else
            Btn.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
            Btn.Text = text .. " [OFF]"
            Btn.TextColor3 = Color3.fromRGB(200, 200, 200)
        end
        callback(active)
    end)
end

-- FUNCIÓN AUXILIAR PARA CREAR BOTONES DE ACCIÓN (BUTTONS)
local function CreateButton(name, text, callback)
    local Btn = Instance.new("TextButton")
    Btn.Name = name
    Btn.Size = UDim2.new(1, -10, 0, 40)
    Btn.BackgroundColor3 = Color3.fromRGB(55, 55, 65)
    Btn.Text = text
    Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Btn.TextSize = 16
    Btn.Font = Enum.Font.SourceSansBold
    Btn.Parent = Container
    
    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(0, 6)
    Corner.Parent = Btn
    
    Btn.MouseButton1Click:Connect(callback)
end

-- 6. ASIGNACIÓN DE LAS FUNCIONES REALES

-- Toggle 1: Auto Grab Ball
CreateToggle("ToggleGrab", "Auto Grab & Stole Basketball", function(state)
    autoGrab = state
    task.spawn(function()
        while autoGrab do
            task.wait(0.1)
            pcall(function()
                for _, obj in pairs(workspace:GetChildren()) do
                    if obj.Name == "Basketball" or obj:FindFirstChild("Ball") then
                        if RootPart and (RootPart.Position - obj.Position).Magnitude < 70 then
                            RootPart.CFrame = obj.CFrame
                        end
                    end
                end
            end)
        end
    end)
end)

-- Toggle 2: Super Velocidad
CreateToggle("ToggleSpeed", "Super Velocidad (WalkSpeed X3)", function(state)
    if state then
        normalSpeed = 65
    else
        normalSpeed = 16
    end
    if Humanoid then Humanoid.WalkSpeed = normalSpeed end
end)

-- Toggle 3: Super Salto
CreateToggle("ToggleJump", "Mega Salto (JumpPower X2)", function(state)
    if state then
        normalJump = 120
    else
        normalJump = 50
    end
    if Humanoid then 
        Humanoid.UseJumpPower = true
        Humanoid.JumpPower = normalJump 
    end
end)

-- Toggle 4: Infinite Jump (Saltar en el aire)
CreateToggle("ToggleInfJump", "Salto Infinito en el Aire", function(state)
