local function CreateTab(name, icon, order)
    local TabBtn = Instance.new("TextButton")
    TabBtn.Name = name .. "Tab"
    TabBtn.Parent = TabContainer
    TabBtn.BackgroundColor3 = Color3.fromRGB(35, 30, 50)
    TabBtn.BackgroundTransparency = 1
    TabBtn.Size = UDim2.new(0, 110, 1, 0)
    TabBtn.Font = Enum.Font.GothamSemibold
    TabBtn.Text = icon .. "  " .. name
    TabBtn.TextColor3 = TextDark
    TabBtn.TextSize = 11
    TabBtn.LayoutOrder = order
    
    local TabCorner = Instance.new("UICorner")
    TabCorner.CornerRadius = UDim.new(0, 20)
    TabCorner.Parent = TabBtn
    
    local TabStroke = Instance.new("UIStroke")
    TabStroke.Color = BorderColor
    TabStroke.Thickness = 1
    TabStroke.Parent = TabBtn

    local PageFrame = Instance.new("ScrollingFrame")
    PageFrame.Name = name .. "Page"
    PageFrame.Parent = MainFrame
    PageFrame.BackgroundTransparency = 1
    PageFrame.Position = UDim2.new(0, 15, 0, 95)
    PageFrame.Size = UDim2.new(1, -30, 1, -110)
    PageFrame.CanvasSize = UDim2.new(0, 0, 0, 500)
    PageFrame.ScrollBarThickness = 2
    PageFrame.ScrollBarImageColor3 = AccentColor
    PageFrame.Visible = false
    
    local PageLayout = Instance.new("UIListLayout")
    PageLayout.Parent = PageFrame
    PageLayout.SortOrder = Enum.SortOrder.LayoutOrder
    PageLayout.Padding = UDim.new(0, 8)
    
    Pages[name] = PageFrame
    Tabs[name] = TabBtn
    
    TabBtn.MouseButton1Click:Connect(function()
        for tName, tBtn in pairs(Tabs) do
            tBtn.BackgroundTransparency = 1
            tBtn.TextColor3 = TextDark
            tBtn.BackgroundColor3 = Color3.fromRGB(0,0,0)
            Pages[tName].Visible = false
        end
        TabBtn.BackgroundTransparency = 0
        TabBtn.BackgroundColor3 = ElementColor
        TabBtn.TextColor3 = AccentColor
        PageFrame.Visible = true
    end)
end

CreateTab("Combat & ESP", "⚔️", 1)
