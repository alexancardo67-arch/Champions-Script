local function FlingPlayer(targetP)
    if targetP and targetP.Character and targetP.Character:FindFirstChild("HumanoidRootPart") then
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if root then
            local oldCF = root.CFrame
            local bav = Instance.new("BodyAngularVelocity", root)
            bav.P = 1e10
            bav.maxTorque = Vector3.new(1e10, 1e10, 1e10)
            bav.angularvelocity = Vector3.new(0, 45000, 0)
            root.CFrame = targetP.Character.HumanoidRootPart.CFrame
            task.wait(0.4)
            bav:Destroy()
            root.CFrame = oldCF
        end
    end
end

CreateButton("FLING MURDER", function() FlingPlayer(GetPlayerByRole("Murderer")) end)
CreateButton("FLING SHERIFF", function() FlingPlayer(GetPlayerByRole("Sheriff")) end)
