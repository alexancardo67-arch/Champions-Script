-- Botón 3: Optimizar FPS / Quitar Animaciones Extra
CreateButton("BtnNoLag", "Optimizar FPS (Quitar Lag Visual)", function()
    pcall(function()
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Smoke") or v:IsA("Sparkles") then
                v.Enabled = false
            end
        end
    end)
end)

-- Mantener la velocidad y el salto activos de forma forzada si el personaje muere o revive
task.spawn(function()
    while true do
        task.wait(0.5)
        if Humanoid then
            Humanoid.WalkSpeed = normalSpeed
            if normalJump ~= 50 then
                Humanoid.UseJumpPower = true
                Humanoid.JumpPower = normalJump
            end
        end
    end
end)

