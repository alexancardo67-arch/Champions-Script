-- SECCIÓN 1: INTELIGENCIA ARTIFICIAL (AUTO-PLAY AUTÓNOMO)
CreateSection("🤖 Jugar Solo (Auto-Play AFK)")

CreateToggle("Auto-Win Autónomo (Juega por ti mismo)", function(state)
    autoPlayMM2 = state
    task.spawn(function()
        while autoPlayMM2 do
            task.wait(0.2)
            pcall(function()
                if RootPart and Humanoid then
                    local Murderer = GetMurderer()
                    local HasKnife = Character:FindFirstChild("Knife") or LocalPlayer.Backpack:FindFirstChild("Knife")
                    local HasGun = Character:FindFirstChild("Gun") or LocalPlayer.Backpack:FindFirstChild("Gun")
                    
                    -- MODO 1: SI ERES EL ASESINO (Mata a todos automáticamente)
                    if HasKnife then
                        if LocalPlayer.Backpack:FindFirstChild("Knife") then Humanoid:EquipTool(LocalPlayer.Backpack.Knife) end
                        for _, p in pairs(Players:GetPlayers()) do
                            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
                                RootPart.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 1.5)
                                task.wait(0.1)
                                if Character:FindFirstChild("Knife") then Character.Knife:Activate() end
                            end
                        end
                        
                    -- MODO 2: SI ERES EL SHERIFF (Elimina al asesino al instante)
                    elseif HasGun then
                        if Murderer and Murderer.Character and Murderer.Character:FindFirstChild("HumanoidRootPart") and Murderer.Character.Humanoid.Health > 0 then
                            if LocalPlayer.Backpack:FindFirstChild("Gun") then Humanoid:EquipTool(LocalPlayer.Backpack.Gun) end
                            RootPart.CFrame = Murderer.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 4)
                            workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, Murderer.Character.HumanoidRootPart.Position)
                            task.wait(0.1)
                            if Character:FindFirstChild("Gun") then Character.Gun:Activate() end
                        end
                        
                    -- MODO 3: SI ERES INOCENTE (Esquívalo y recolecta monedas)
                    else
                        -- Escapar del asesino si está muy cerca
                        if Murderer and Murderer.Character and Murderer.Character:FindFirstChild("HumanoidRootPart") then
                            local dist = (RootPart.Position - Murderer.Character.HumanoidRootPart.Position).Magnitude
                            if dist < 30 then
                                -- Teletransportar al lado opuesto aleatorio arriba
                                RootPart.CFrame = RootPart.CFrame * CFrame.new(math.random(-60, 60), 15, math.random(-60, 60))
                            end
                        end
                        
                        -- Auto Recoger Monedas mientras esquiva
                        for _, v in pairs(workspace:GetDescendants()) do
                            if v.Name == "Coin_SubModel" or v.Name == "Coin" then
                                if RootPart and v:IsA("BasePart") then 
                                    RootPart.CFrame = v.CFrame 
                                    task.wait(0.1) 
                                    break 
                                end
                            end
                        end
                    end
                end
            end)
        end
    end)
end)

