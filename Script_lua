CreateToggle("FLY", function(state)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if state and root then
        if Connections["FlyLoop"] then Connections["FlyLoop"]:Disconnect() end
        local bg = Instance.new("BodyGyro", root)
        bg.P = 9e4
        bg.maxTorque = Vector3.new(9e9, 9e9, 9e9)
        bg.cframe = root.CFrame
        local bv = Instance.new("BodyVelocity", root)
        bv.velocity = Vector3.new(0, 0, 0)
        bv.maxForce = Vector3.new(9e9, 9e9, 9e9)
        
        Connections["FlyLoop"] = RunService.RenderStepped:Connect(function()
            if Toggles["FLY"] and char and root then
                local moveDir = char.Humanoid.MoveDirection
                local vel = Vector3.new(0, 0, 0)
                if moveDir.Magnitude > 0 then
                    vel = Camera.CFrame.LookVector * moveDir.Z + Camera.CFrame.RightVector * moveDir.X
                end
                bv.velocity = vel * Config.FlySpeed
                bg.cframe = Camera.CFrame
            else
                bg:Destroy()
                bv:Destroy()
                Connections["FlyLoop"]:Disconnect()
            end
        end)
    elseif not state and Connections["FlyLoop"] then
        Connections["FlyLoop"]:Disconnect()
    end
end)
