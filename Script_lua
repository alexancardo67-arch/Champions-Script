    RowCorner.CornerRadius = UDim.new(0, 8)
    RowCorner.Parent = RowFrame
    
    local RowStroke = Instance.new("UIStroke")
    RowStroke.Color = BorderColor
    RowStroke.Parent = RowFrame
    
    local Label = Instance.new("TextLabel")
    Label.Parent = RowFrame
    Label.BackgroundTransparency = 1
    Label.Position = UDim2.new(0, 15, 0, 0)
    Label.Size = UDim2.new(0.7, 0, 1, 0)
    Label.Font = Enum.Font.GothamSemibold
    Label.Text = text
    Label.TextColor3 = TextMain
    Label.TextSize = 12
    Label.TextXAlignment = Enum.TextXAlignment.Left
    
    local Switch = Instance.new("TextButton")
    Switch.Parent = RowFrame
    Switch.BackgroundColor3 = BorderColor
    Switch.Position = UDim2.new(1, -55, 0.25, 0)
    Switch.Size = UDim2.new(0, 40, 0, 20)
    Switch.Text = ""
    
    local SwitchCorner = Instance.new("UICorner")
    SwitchCorner.CornerRadius = UDim.new(0, 10)
    SwitchCorner.Parent = Switch
    
    local Circle = Instance.new("Frame")
    Circle.Parent = Switch
    Circle.BackgroundColor3 = TextDark
    Circle.Position = UDim2.new(0.08, 0, 0.1, 0)
    Circle.Size = UDim2.new(0, 16, 0, 16)
    
    local CircleCorner = Instance.new("UICorner")
    CircleCorner.CornerRadius = UDim.new(1, 0)
    CircleCorner.Parent = Circle
    
    Switch.MouseButton1Click:Connect(function()
        state = not state
        Toggles[text] = state
        if state then
            Switch.BackgroundColor3 = AccentColor
            Circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Circle.Position = UDim2.new(0.52, 0, 0.1, 0)
        else
            Switch.BackgroundColor3 = BorderColor
            Circle.BackgroundColor3 = TextDark
            Circle.Position = UDim2.new(0.08, 0, 0.1, 0)
        end
        callback(state)
    end)
end

