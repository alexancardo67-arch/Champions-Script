-- [[ NBA Champions - SILLET CLIENT V2.1 ]]
-- Usamos una versión optimizada de Orion que carga al instante en Delta
local OrionLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/shlexware/Orion/main/source"))()

-- Crear la ventana principal sin intro para evitar bloqueos
local Window = OrionLib:MakeWindow({
    Name = "SILLET CLIENT V2 - NBA Champions",
    HidePremium = false,
    SaveConfig = false,
    IntroText = "Iniciando..."
})

-- Variables de Control del Jugador
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local RootPart = Character:WaitForChild("HumanoidRootPart")
local Humanoid = Character:WaitForChild("Humanoid")

LocalPlayer.CharacterAdded:Connect(function(char)
    Character = char
    RootPart = char:WaitForChild("HumanoidRootPart")
    Humanoid = char:WaitForChild("Humanoid")
end)

-- PESTAÑA 1: BALONCESTO
local MainTab = Window:MakeTab({
    Name = "Baloncesto",
    Icon = "rbxassetid://4483345998"
})

local autoGrab = false
MainTab:AddToggle({
    Name = "Auto Grab & Stole Basketball",
    Default = false,
    Callback = function(Value)
        autoGrab = Value
        task.spawn(function()
            while autoGrab do
                task.wait(0.1)
                pcall(function()
                    for _, obj in pairs(workspace:GetChildren()) do
                        if obj.Name == "Basketball" or obj:FindFirstChild("Ball") then
                            local distance = (RootPart.Position - obj.Position).Magnitude
                            if distance < 60 then
                                RootPart.CFrame = obj.CFrame
                            end
                        end
                    end
                end)
            end
        end)
    end
})

local autoScore = false
MainTab:AddToggle({
    Name = "Auto Meter Pelota (Auto Score)",
    Default = false,
    Callback = function(Value)
        autoScore = Value
        task.spawn(function()
            while autoScore do
                task.wait(0.1)
                pcall(function()
                    local Goal = workspace:FindFirstChild("Hoop") or workspace:FindFirstChild("Basket")
                    if Goal and Character:FindFirstChildOfClass("Tool") then
                        RootPart.CFrame = Goal.CFrame + Vector3.new(0, 6, 0)
                    end
                end)
            end
        end)
    end
})

-- PESTAÑA 2: JUGADOR
local PlayerTab = Window:MakeTab({
    Name = "Jugador",
    Icon = "rbxassetid://4483345998"
})

PlayerTab:AddSlider({
    Name = "Velocidad (WalkSpeed)",
    Min = 16,
    Max = 150,
    Default = 16,
    Color = Color3.fromRGB(185, 130, 250),
    Increment = 1,
    ValueName = "Speed",
    Callback = function(Value)
        if Humanoid then
            Humanoid.WalkSpeed = Value
        end
    end
})

PlayerTab:AddSlider({
    Name = "Fuerza de Salto (JumpPower)",
    Min = 50,
    Max = 300,
    Default = 50,
    Color = Color3.fromRGB(185, 130, 250),
    Increment = 1,
    ValueName = "Power",
    Callback = function(Value)
        if Humanoid then
            Humanoid.JumpPower = Value
        end
    end
})

-- PESTAÑA 3: TELEPORTS
local TeleportTab = Window:MakeTab({
    Name = "Teleports",
    Icon = "rbxassetid://4483345998"
})

TeleportTab:AddButton({
    Name = "Teleport al Aro Central",
    Callback = function()
        pcall(function()
            local Hoop = workspace:FindFirstChild("Hoop")
            if Hoop then RootPart.CFrame = Hoop.CFrame end
        end)
    end
})

TeleportTab:AddButton({
    Name = "Teleport al Lobby (Spawn)",
    Callback = function()
        pcall(function()
            local Spawn = workspace:FindFirstChildOfClass("SpawnLocation")
            if Spawn then RootPart.CFrame = Spawn.CFrame + Vector3.new(0, 3, 0) end
        end)
    end
})

OrionLib:Init()
