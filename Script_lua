-- [[ NBA Champions - SILLET CLIENT V2.5 ]]
local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()

-- Crear la ventana principal (Fluent maneja el botón flotante automáticamente)
local Window = Fluent:CreateWindow({
    Title = "SILLET CLIENT V2.5",
    SubTitle = "by Kevin",
    TabWidth = 160,
    Size = UDim2.fromOffset(580, 460),
    Acrylic = false, -- Desactivado para que no cause lag en tablets/iOS
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.LeftControl -- Keybind por defecto
})

-- Variables Principales del Jugador
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local RootPart = Character:WaitForChild("HumanoidRootPart")
local Humanoid = Character:WaitForChild("Humanoid")

LocalPlayer.CharacterAdded:Connect(function(char)
    Character = char
    RootPart = char:WaitForChild("HumanoidRootPart")
    Humanoid = char:WaitForChild("Humanoid")
end)

-- PESTAÑA 1: BALONCESTO
local Tabs = {
    Main = Window:AddTab({ Title = "Baloncesto", Icon = "basketball" }),
    Player = Window:AddTab({ Title = "Jugador", Icon = "user" }),
    Teleports = Window:AddTab({ Title = "Teleports", Icon = "map-pin" })
}

-- Funciones de Automatización
local autoGrab = false
local ToggleGrab = Tabs.Main:AddToggle("AutoGrab", {Title = "Auto Grab & Stole Basketball", Default = false})

ToggleGrab:OnChanged(function()
    autoGrab = ToggleGrab.Value
    task.spawn(function()
        while autoGrab do
            task.wait(0.1)
            pcall(function()
                for _, obj in pairs(workspace:GetChildren()) do
                    if obj.Name == "Basketball" or obj:FindFirstChild("Ball") then
                        local distance = (RootPart.Position - obj.Position).Magnitude
                        if distance < 60 then
                            RootPart.CFrame = obj.CFrame
                        end
                    end
                end
            end)
        end
    end)
end)

local autoScore = false
local ToggleScore = Tabs.Main:AddToggle("AutoScore", {Title = "Auto Meter Pelota (Auto Score)", Default = false})

ToggleScore:OnChanged(function()
    autoScore = ToggleScore.Value
    task.spawn(function()
        while autoScore do
            task.wait(0.1)
            pcall(function()
                local Goal = workspace:FindFirstChild("Hoop") or workspace:FindFirstChild("Basket")
                if Goal and Character:FindFirstChildOfClass("Tool") then
                    RootPart.CFrame = Goal.CFrame + Vector3.new(0, 6, 0)
                end
            end)
        end
    end)
end)

-- PESTAÑA 2: MEJORAS DE JUGADOR
local SliderSpeed = Tabs.Player:AddSlider("SliderSpeed", {
    Title = "Velocidad (WalkSpeed)",
    Description = "Ajusta la velocidad de tu personaje",
    Min = 16,
    Max = 150,
    Default = 16,
    Rounding = 0,
    Callback = function(Value)
        if Humanoid then Humanoid.WalkSpeed = Value end
    end
})

local SliderJump = Tabs.Player:AddSlider("SliderJump", {
    Title = "Fuerza de Salto (JumpPower)",
    Description = "Salta más alto para alcanzar el aro",
    Min = 50,
    Max = 300,
    Default = 50,
    Rounding = 0,
    Callback = function(Value)
        if Humanoid then 
            Humanoid.UseJumpPower = true
            Humanoid.JumpPower = Value 
        end
    end
})

-- PESTAÑA 3: TELEPORTS
Tabs.Teleports:AddButton({
    Title = "Teleport al Aro Central",
    Callback = function()
        pcall(function()
            local Hoop = workspace:FindFirstChild("Hoop")
            if Hoop then RootPart.CFrame = Hoop.CFrame end
        end)
    end
})

Tabs.Teleports:AddButton({
    Title = "Teleport al Lobby (Spawn)",
    Callback = function()
        pcall(function()
            local Spawn = workspace:FindFirstChildOfClass("SpawnLocation")
            if Spawn then RootPart.CFrame = Spawn.CFrame + Vector3.new(0, 3, 0) end
        end)
    end
})

-- Seleccionar la primera pestaña al abrir
Window:SelectTab(1)
