--====================================================================--
--                         HIGHLIGHTS ENGINE                          --
--====================================================================--

local function ApplyHighlight(player, color)
    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        if not player.Character:FindFirstChild("WDSN_Wallhack") then
            local hl = Instance.new("Highlight")
            hl.Name = "WDSN_Wallhack"
            hl.FillColor = color
            hl.OutlineColor = Color3.fromRGB(255, 255, 255)
            hl.FillTransparency = 0.4
            hl.OutlineTransparency = 0
            hl.Adornee = player.Character
            hl.Parent = player.Character
        else
            player.Character.WDSN_Wallhack.FillColor = color
        end
    end
end

local function RemoveHighlight(player)
    if player.Character and player.Character:FindFirstChild("WDSN_Wallhack") then
        player.Character.WDSN_Wallhack:Destroy()
    end
end

